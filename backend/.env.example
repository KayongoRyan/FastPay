PORT=3000

# Stellar testnet (defaults match testnet if unset)
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org

# MongoDB
MONGODB_URI=mongodb://localhost:27017/FastPay

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Offline relay queue
OFFLINE_QUEUE_NAME=offline-tx
OFFLINE_ESTIMATED_SECONDS=120
OFFLINE_RETRY_ATTEMPTS=5
OFFLINE_RETRY_BACKOFF_MS=5000
