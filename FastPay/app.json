{
  "expo": {
    "name": "FastPay Wallet",
    "slug": "fastpay-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fastpay",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fastpay.wallet"
    },
    "android": {
      "package": "com.fastpay.wallet",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://fastpay.app"
        }
      ],
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow FastPay to unlock your wallet with Face ID."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FastPay to scan offline payment QR codes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
