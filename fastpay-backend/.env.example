# FastPay Backend Environment

# MongoDB
MONGODB_URI=mongodb://localhost:27018/FastPay
MONGODB_DB_NAME=FastPay

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6380

# Stellar / mock Horizon
STELLAR_HORIZON_URL=http://localhost:8090
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_FRIENDBOT_URL=http://localhost:8090/friendbot

# Service URLs (local dev)
AUTH_SERVICE_URL=http://localhost:3001
BLOCKCHAIN_SERVICE_URL=http://localhost:3009
PAYMENT_SERVICE_URL=http://localhost:3003
FRAUD_SERVICE_URL=http://localhost:3011

# Compliance mock (runs inside fraud-service)
CHAINALYSIS_MOCK_URL=http://localhost:3011/compliance/chainalysis
CHAINALYSIS_API_KEY=mock-api-key

# Offline relay
OFFLINE_QUEUE_NAME=offline-tx
OFFLINE_ESTIMATED_SECONDS=120
OFFLINE_RETRY_ATTEMPTS=5
OFFLINE_RETRY_BACKOFF_MS=5000

# JWT (auth-service)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_LOCKOUT_SECONDS=900
AUTH_REGISTER_MAX_PER_IP=10
AUTH_REGISTER_WINDOW_SECONDS=3600

# Ports
GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
PORT=3000
